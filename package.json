{
  "name": "glaszrtev",
  "version": "1.0.0",
  "description": "#GlasŽrtev — anonimiziran števec sovražnega govora v Sloveniji",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc server/index.ts --outDir dist/server --module esnext --target es2022 --moduleResolution bundler",
    "start": "node dist/server/index.js",
    "db:seed": "tsx server/seed.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "vite": "^6.0.0",
    "typescript": "^5.6.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0"
  }
}
